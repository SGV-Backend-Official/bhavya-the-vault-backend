<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Email Verification OTP</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background: #f5f5f5;
      font-family: Arial, sans-serif;
    "
  >
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            style="
              background: #ffffff;
              margin-top: 40px;
              border-radius: 10px;
              overflow: hidden;
            "
          >
            <!-- Header -->
            <tr>
              <td
                align="center"
                style="
                  background: #111827;
                  padding: 30px;
                  color: #ffffff;
                  font-size: 28px;
                  font-weight: bold;
                "
              >
                The Vault Poker
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding: 40px; color: #333333">
                <h2><%= emailGreeting %></h2>

                <p style="font-size: 16px; line-height: 26px">
                  Please use the OTP below to verify your email address.
                </p>

                <!-- OTP -->
                <div style="text-align: center; margin: 40px 0">
                  <div
                    style="
                      display: inline-block;
                      background: #111827;
                      color: #ffffff;
                      padding: 18px 40px;
                      font-size: 36px;
                      font-weight: bold;
                      border-radius: 8px;
                      letter-spacing: 8px;
                    "
                  >
                    <%= otp %>
                  </div>
                </div>

                <p style="font-size: 15px; color: #666666">
                  This OTP is valid for 10 minutes.
                </p>

                <p style="margin-top: 30px; font-size: 15px">
                  If you did not request this, please ignore this email.
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                align="center"
                style="
                  background: #f3f4f6;
                  padding: 20px;
                  font-size: 14px;
                  color: #666666;
                "
              >
                © 2026 The Vault Poker
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
